# --- База: Supabase Postgres (Settings → Database) ---
# Pooled (Transaction pooler, порт 6543) — для runtime на Vercel
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct (порт 5432) — для prisma migrate deploy и prisma db seed
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

SESSION_SECRET="change-me-to-long-random-string-min-32-chars"
# Хэш пароля: node -e "console.log(require('bcryptjs').hashSync('ВАШ_ПАРОЛЬ',10))"
# В хэше bcrypt экранируйте каждый $ как \$ (иначе Next.js обрежет переменную)
ADMIN_PASSWORD_HASH="\$2b\$10\$ЗАМЕНИТЕ_НА_ВАШ_ХЭШ"

# Публичный URL продакшена (canonical, OG, sitemap)
NEXT_PUBLIC_SITE_URL="https://your-domain.vercel.app"

# --- Медиа на Vercel: Supabase Storage (локально можно не задавать — файлы в public/media) ---
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="service_role_секрет_из_Supabase"
SUPABASE_STORAGE_BUCKET="media"

# Опционально: Supabase Auth (обновление сессии в proxy + SSR). Без них сайт работает, админка — по JWT как раньше.
# NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..." 
# или ключ «Publishable» из дашборда:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="sb_publishable_..."

# Опционально: Plausible Analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""

# Опционально: Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# Локально: папка для оригиналов и вариантов (если без Supabase Storage)
MEDIA_ROOT="storage/media"
