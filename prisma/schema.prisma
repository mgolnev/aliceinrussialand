generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SocialSourcePlatform {
  TELEGRAM
  INSTAGRAM
  BEHANCE
}

model SiteSettings {
  id                   Int     @id @default(1)
  displayName          String  @default("Иллюстратор")
  tagline              String  @default("")
  bio                  String  @default("")
  aboutMarkdown        String  @default("")
  avatarMediaPath      String?
  /// JSON с вариантами фото для страницы «Обо мне» (w640 / w960 / w1280).
  aboutPhotoPath       String?
  socialLinksJson      String  @default("[]")
  telegramChannelUser  String  @default("")
  /// Подпись ссылки на /about в шапке и заголовок блока соцсетей на странице «Обо мне».
  contactsLabel        String  @default("Контакты")
  defaultLocale        String  @default("ru")
  siteUrl              String  @default("http://localhost:3000")
  plausibleDomain      String  @default("")
  yandexMetrikaId      String  @default("")
  yandexVerification   String  @default("")
  updatedAt            DateTime @updatedAt
}

model PostCategory {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  description String @default("")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts     Post[]
}

model Post {
  id                 String         @id @default(cuid())
  slug               String         @unique
  title              String
  body               String         @default("")
  displayMode        String         @default("GRID")
  status             String         @default("DRAFT")
  publishedAt        DateTime?
  pinned             Boolean        @default(false)
  metaTitle          String         @default("")
  metaDescription    String         @default("")
  telegramSourceUrl  String?
  sourcePlatform     SocialSourcePlatform?
  sourceUrl          String?
  sourceExternalId   String?
  locale             String         @default("ru")
  categoryId         String?
  category           PostCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  images             PostImage[]

  @@index([status, publishedAt])
  @@index([categoryId])
  @@index([status, pinned, publishedAt(sort: Desc)])
  @@index([sourcePlatform, sourceUrl])
  @@index([sourcePlatform, sourceExternalId])
}

model PostImage {
  id          String   @id @default(cuid())
  postId      String
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  sortOrder   Int      @default(0)
  caption     String   @default("")
  alt         String   @default("")
  originalExt String   @default("jpg")
  width       Int?
  height      Int?
  variantsJson String  @default("{}")
  createdAt   DateTime @default(now())

  @@index([postId, sortOrder])
}
